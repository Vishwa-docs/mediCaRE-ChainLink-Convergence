FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build args → env vars for Next.js build
ARG NEXT_PUBLIC_THIRDWEB_CLIENT_ID=demo
ARG NEXT_PUBLIC_CHAIN_ID=99911155111
ARG NEXT_PUBLIC_RPC_URL
ARG NEXT_PUBLIC_EHR_ADDRESS
ARG NEXT_PUBLIC_INSURANCE_ADDRESS
ARG NEXT_PUBLIC_SUPPLY_ADDRESS
ARG NEXT_PUBLIC_CREDENTIAL_ADDRESS
ARG NEXT_PUBLIC_GOVERNANCE_ADDRESS
ARG NEXT_PUBLIC_STABLECOIN_ADDRESS
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_DEMO_ADDRESS
ARG NEXT_PUBLIC_WORLDID_APP_ID
ARG NEXT_PUBLIC_WORLDID_ACTION

ENV NEXT_PUBLIC_THIRDWEB_CLIENT_ID=$NEXT_PUBLIC_THIRDWEB_CLIENT_ID
ENV NEXT_PUBLIC_CHAIN_ID=$NEXT_PUBLIC_CHAIN_ID
ENV NEXT_PUBLIC_RPC_URL=$NEXT_PUBLIC_RPC_URL
ENV NEXT_PUBLIC_EHR_ADDRESS=$NEXT_PUBLIC_EHR_ADDRESS
ENV NEXT_PUBLIC_INSURANCE_ADDRESS=$NEXT_PUBLIC_INSURANCE_ADDRESS
ENV NEXT_PUBLIC_SUPPLY_ADDRESS=$NEXT_PUBLIC_SUPPLY_ADDRESS
ENV NEXT_PUBLIC_CREDENTIAL_ADDRESS=$NEXT_PUBLIC_CREDENTIAL_ADDRESS
ENV NEXT_PUBLIC_GOVERNANCE_ADDRESS=$NEXT_PUBLIC_GOVERNANCE_ADDRESS
ENV NEXT_PUBLIC_STABLECOIN_ADDRESS=$NEXT_PUBLIC_STABLECOIN_ADDRESS
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_DEMO_ADDRESS=$NEXT_PUBLIC_DEMO_ADDRESS
ENV NEXT_PUBLIC_WORLDID_APP_ID=$NEXT_PUBLIC_WORLDID_APP_ID
ENV NEXT_PUBLIC_WORLDID_ACTION=$NEXT_PUBLIC_WORLDID_ACTION

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

EXPOSE 3000

CMD ["node", "server.js"]
