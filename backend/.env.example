# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ─── Supabase (PostgreSQL) ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── JWT / Auth ───────────────────────────────────────────
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRES_IN=24h

# ─── Blockchain / Ethers ─────────────────────────────────
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
PRIVATE_KEY=0x_YOUR_DEPLOYER_PRIVATE_KEY
CHAIN_ID=11155111

# ─── Contract Addresses (deploy first, then fill in) ─────
EHR_STORAGE_ADDRESS=0x0000000000000000000000000000000000000000
INSURANCE_POLICY_ADDRESS=0x0000000000000000000000000000000000000000
SUPPLY_CHAIN_ADDRESS=0x0000000000000000000000000000000000000000
CREDENTIAL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
GOVERNANCE_ADDRESS=0x0000000000000000000000000000000000000000

# ─── IPFS / Pinata ───────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── Azure OpenAI ────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ─── FHIR Server ────────────────────────────────────────
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_AUTH_TOKEN=

# ─── World ID ───────────────────────────────────────────
WORLDID_APP_ID=app_your_world_id
WORLDID_ACTION=verify-human
WORLDID_API_URL=https://developer.worldcoin.org/api/v2/verify

# ─── Encryption ─────────────────────────────────────────
ENCRYPTION_KEY=32-byte-hex-key-change-me-please!!
ENCRYPTION_IV_LENGTH=16

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
