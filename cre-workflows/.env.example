# ──────────────────────────────────────────────────────────────
#  mediCaRE — CRE Environment Variables
#  Copy to .env and fill in real values. NEVER commit .env.
# ──────────────────────────────────────────────────────────────

# ── Wallet ───────────────────────────────────────────────────
CRE_ETH_PRIVATE_KEY=<your_deployer_private_key>
WORKFLOW_OWNER_ADDRESS=<your_workflow_owner_address>

# ── RPC Endpoints ────────────────────────────────────────────
CRE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CRE_OP_SEPOLIA_RPC_URL=https://optimism-sepolia-rpc.publicnode.com
CRE_BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com

# ── IPFS ─────────────────────────────────────────────────────
IPFS_GATEWAY_TOKEN_VALUE=<your_ipfs_gateway_token>

# ── AI Services ──────────────────────────────────────────────
AI_SUMMARIZER_API_KEY_VALUE=<your_ai_summarizer_api_key>
RISK_SCORING_API_KEY_VALUE=<your_risk_scoring_api_key>

# ── World ID ─────────────────────────────────────────────────
WORLD_ID_APP_ID_VALUE=app_<your_world_id_app_id>
WORLD_ID_ACTION_ID_VALUE=<your_world_id_action_id>

# ── IoT Oracle ───────────────────────────────────────────────
IOT_ORACLE_API_KEY_VALUE=<your_iot_oracle_api_key>

# ── CCIP Bridge ──────────────────────────────────────────────
CCIP_BRIDGE_API_KEY_VALUE=<your_ccip_bridge_api_key>

# ── Backend Auth ─────────────────────────────────────────────
MEDICARE_BACKEND_AUTH_TOKEN_VALUE=<your_backend_auth_token>

# ── HTTP Trigger Auth (for deployed workflows) ───────────────
AUTHORIZED_EVM_ADDRESS=<evm_address_authorized_to_trigger_workflows>
