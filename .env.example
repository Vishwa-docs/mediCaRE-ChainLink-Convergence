# ============================================================
# mediCaRE Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Blockchain ---
PRIVATE_KEY=your_wallet_private_key_here
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY
ETHERSCAN_API_KEY=your_etherscan_api_key

# --- Chainlink ---
LINK_TOKEN_SEPOLIA=0x779877A7B0D9E8603169DdbD7836e478b4624789
CCIP_ROUTER_SEPOLIA=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
CRE_API_KEY=your_cre_api_key
CRE_ETH_PRIVATE_KEY=your_cre_private_key
CRE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# --- AI Services ---
OPENAI_API_KEY=your_openai_api_key
AI_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_MODEL_NAME=gpt-4o-mini

# --- IPFS (Pinata) ---
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# --- World ID ---
WORLDID_APP_ID=app_your_world_id_app_id
WORLDID_ACTION_ID=verify-human

# --- FHIR Server ---
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4
FHIR_AUTH_TOKEN=optional_auth_token

# --- Tenderly ---
TENDERLY_PROJECT=mediCaRE
TENDERLY_USERNAME=your_tenderly_username
TENDERLY_ACCESS_KEY=your_tenderly_access_key
TENDERLY_FORK_ID=your_fork_id

# --- Backend ---
PORT=4000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_for_backend_auth
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
NEXT_PUBLIC_WORLDID_APP_ID=app_your_world_id_app_id
